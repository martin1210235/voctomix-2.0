# Voctomix 2.0 — environment variable template
# Copy to .env and adjust for your host. All variables are optional: the launch
# scripts auto-detect the LAN IP from the routing table when unset.

# ---- Native scenarios (single-PC / two-PC) ----

# Override the auto-detected LAN IP of the host running voctocore.
# LOCAL_IP=10.0.0.5

# On the operator machine (PC 2), address of the server machine (PC 1).
# IP_SERVER=10.0.0.5

# ---- Docker Compose scenario ----

# Override the auto-detected host IP injected into containers.
# HOST_IP=10.0.0.5

# IP announced by the telemetry service (defaults to the detected LAN IP).
# MI_IP_REAL=10.0.0.5

# ---- RabbitMQ (telemetry broker) ----
# Defaults match docker-compose.yml; change only if you alter the broker config.
# RABBITMQ_DEFAULT_USER=guest
# RABBITMQ_DEFAULT_PASS=guest
