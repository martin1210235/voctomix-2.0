# .env.example — Environment variables for docker-compose.yml
# Copy to .env and fill in values:  cp .env.example .env

# ─── Video format ────────────────────────────────────────────────────────────
WIDTH=1920
HEIGHT=1080
FRAMERATE=25
AUDIORATE=48000

# ─── RabbitMQ credentials ────────────────────────────────────────────────────
RABBITMQ_USER=voctomix
RABBITMQ_PASS=voctomix123

# ─── Telemetry ───────────────────────────────────────────────────────────────
# IP of the host machine (required by telemetry service for UDP)
HOST_IP=192.168.1.100
SAVE_LOGS=false

# ─── Docker user (prevents permission issues with mounted volumes) ────────────
COMPOSE_UID=1000
COMPOSE_GID=1000

# ─── Camera sources (URLs or local paths) ────────────────────────────────────
# Leave blank to use the default demo videos (CCC conference recordings)
CAM1_SOURCE=
CAM2_SOURCE=
CAM3_SOURCE=
CAM4_SOURCE=

CAM1_PORT=10000
CAM2_PORT=10001
CAM3_PORT=10002
CAM4_PORT=10003

# ─── Break / Pause source ────────────────────────────────────────────────────
BREAK_VIDEO=/opt/voctomix/videos/video_cuenta_regresiva_10s.mp4
BREAK_AUDIO=/opt/voctomix/videos/musica_pausa.mp3
BREAK_PORT=10004

# ─── Intro source ────────────────────────────────────────────────────────────
INTRO_VIDEO=/opt/voctomix/videos/intro.mp4
INTRO_PORT=10005

# ─── Stream blanker sources ──────────────────────────────────────────────────
PAUSE_VIDEO=/opt/voctomix/videos/SLIDES_video_starting_soon.mp4
OFFLINE_VIDEO=/opt/voctomix/videos/stream_offline.mp4
BLANKER_PAUSE_PORT=17000
BLANKER_OFFLINE_PORT=17001

# ─── Background audio ────────────────────────────────────────────────────────
BACKGROUND_MUSIC=/opt/voctomix/videos/musica_pausa.mp3
AUDIO_PORT=18000
