    given-names: "Martín"
    affiliation: "ETSIT, Universidad Politécnica de Madrid (UPM)"
date-released: 2026
license: MIT
repository-code: "https://github.com/martin1210235/voctomix-2.0"
keywords:
  - live video mixing
  - GStreamer
  - remote production
  - broadcasting
  - Docker
  - Kubernetes
