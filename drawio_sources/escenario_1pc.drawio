<mxfile host="app.diagrams.net">
  <diagram id="escenario_1pc" name="Escenario 1 PC">
    <mxGraphModel dx="1200" dy="380" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="340" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- PC container -->
        <mxCell id="pc" value="PC (único equipo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6699FF;strokeWidth=2;dashed=1;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1160" height="300" as="geometry"/>
        </mxCell>

        <!-- FFmpeg sources -->
        <mxCell id="ffmpeg" value="FFmpeg&#xa;fuentes de señal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- voctocore -->
        <mxCell id="voctocore" value="voctocore.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#FF8800;fontColor=#333333;fontSize=13;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="470" y="100" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- output -->
        <mxCell id="output" value="Salida de programa · :15000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="240" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- voctogui -->
        <mxCell id="voctogui" value="voctogui.py&#xa;host = localhost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="920" y="120" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrow: FFmpeg → voctocore -->
        <mxCell id="a1" value=":10000–10005&#xa;RAW I420" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;strokeColor=#666666;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ffmpeg" target="voctocore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctocore → output -->
        <mxCell id="a2" value=":15000" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;strokeColor=#6c8ebf;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="voctocore" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctogui ↔ voctocore (control) -->
        <mxCell id="a3" value=":9999 control TCP" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;strokeColor=#82b366;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="voctogui" target="voctocore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
