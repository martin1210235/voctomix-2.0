<mxfile host="app.diagrams.net">
  <diagram id="escenario_2pc" name="Escenario 2 PCs">
    <mxGraphModel dx="1200" dy="380" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="340" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- PC1 container -->
        <mxCell id="pc1" value="PC1 · Servidor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6699FF;strokeWidth=2;dashed=1;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="560" height="300" as="geometry"/>
        </mxCell>

        <!-- PC2 container -->
        <mxCell id="pc2" value="PC2 · Realizador" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6699FF;strokeWidth=2;dashed=1;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="620" y="20" width="560" height="300" as="geometry"/>
        </mxCell>

        <!-- FFmpeg sources (PC1) -->
        <mxCell id="ffmpeg" value="FFmpeg&#xa;fuentes de señal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- voctocore (PC1) -->
        <mxCell id="voctocore" value="voctocore.py&#xa;:9999 · :15000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#FF8800;fontColor=#333333;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="310" y="110" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- voctogui (PC2) -->
        <mxCell id="voctogui" value="voctogui.py&#xa;host = IP_SERVER" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="660" y="100" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- Monitor (PC2) -->
        <mxCell id="monitor" value="Monitor de programa&#xa;:15000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="220" width="220" height="65" as="geometry"/>
        </mxCell>

        <!-- LAN label -->
        <mxCell id="lan" value="Red local&#xa;(LAN)" style="text;html=1;align=center;fontStyle=2;fontSize=12;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="566" y="140" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Arrow: FFmpeg → voctocore -->
        <mxCell id="a1" value=":10000–10005" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;strokeColor=#666666;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ffmpeg" target="voctocore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctogui → voctocore (control, LAN) -->
        <mxCell id="a2" value=":9999 control TCP" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;strokeColor=#82b366;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;" edge="1" source="voctogui" target="voctocore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctocore → monitor (program, LAN) -->
        <mxCell id="a3" value=":15000 programa" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;strokeColor=#6c8ebf;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="voctocore" target="monitor" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
