<mxfile host="app.diagrams.net">
  <diagram id="escenario_kubernetes" name="Escenario Kubernetes">
    <mxGraphModel dx="1200" dy="420" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="420" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Cluster box (PC1) -->
        <mxCell id="cluster" value="PC1 · Clúster Kubernetes (Minikube)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6699FF;strokeWidth=2;dashed=1;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="860" height="380" as="geometry"/>
        </mxCell>

        <!-- Pod studio box -->
        <mxCell id="pod_studio" value="Pod: studio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6699FF;strokeWidth=1;dashed=1;fontSize=11;fontStyle=2;verticalAlign=top;spacingTop=4;align=center;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="620" height="220" as="geometry"/>
        </mxCell>

        <!-- voctocore -->
        <mxCell id="voctocore" value="Voctocore&#xa;:9999 · :15000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#FF8800;fontColor=#333333;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Fuentes (cameras + blanker + intro) -->
        <mxCell id="sources" value="Fuentes de señal&#xa;(cam1–4, blanker, intro)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="140" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Telemetria -->
        <mxCell id="telemetry" value="Telemetría&#xa;:8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="155" width="110" height="70" as="geometry"/>
        </mxCell>

        <!-- RabbitMQ pod -->
        <mxCell id="rabbitmq" value="Pod: RabbitMQ&#xa;:5672 · :15672" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="150" height="80" as="geometry"/>
        </mxCell>

        <!-- PVC -->
        <mxCell id="pvc" value="PVC sessions&#xa;(1 GiB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="330" width="130" height="55" as="geometry"/>
        </mxCell>

        <!-- Service / port-forward label -->
        <mxCell id="svc" value="Service NodePort&#xa;+ port-forward" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="680" y="310" width="170" height="60" as="geometry"/>
        </mxCell>

        <!-- PC2 box -->
        <mxCell id="pc2" value="PC2 · Realizador" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6699FF;strokeWidth=2;dashed=1;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="260" height="300" as="geometry"/>
        </mxCell>

        <!-- voctogui -->
        <mxCell id="voctogui" value="Voctogui&#xa;(host = IP_SERVER)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="940" y="130" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Salida de programa -->
        <mxCell id="output" value="Salida de programa&#xa;:15000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="260" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Arrow: sources → voctocore -->
        <mxCell id="a1" value=":10000–10005" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="sources" target="voctocore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctocore → telemetry -->
        <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="voctocore" target="telemetry" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: telemetry → rabbitmq (AMQP) -->
        <mxCell id="a3" value="AMQP" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#d6b656;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="telemetry" target="rabbitmq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctocore → PVC -->
        <mxCell id="a4" value="logs .jsonl" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=1;strokeColor=#666666;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="voctocore" target="pvc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: cluster → service (port-forward) -->
        <mxCell id="a5" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=1;strokeColor=#6c8ebf;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="voctocore" target="svc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: svc → voctogui -->
        <mxCell id="a6" value=":9999" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="svc" target="voctogui" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: svc → output -->
        <mxCell id="a7" value=":15000" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#6c8ebf;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="svc" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
