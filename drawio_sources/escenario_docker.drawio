<mxfile host="app.diagrams.net">
  <diagram id="escenario_docker" name="Escenario Docker">
    <mxGraphModel dx="1200" dy="380" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="380" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Host machine container -->
        <mxCell id="host" value="Equipo anfitrión (make docker-up)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6699FF;strokeWidth=2;dashed=1;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=6;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1160" height="340" as="geometry"/>
        </mxCell>

        <!-- Shared namespace container -->
        <mxCell id="ns" value="Namespace de red compartido (network_mode: service:voctocore)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6699FF;strokeWidth=1;dashed=1;fontSize=11;fontStyle=2;verticalAlign=top;spacingTop=4;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="800" height="240" as="geometry"/>
        </mxCell>

        <!-- voctocore -->
        <mxCell id="voctocore" value="&lt;b&gt;voctocore.py&lt;/b&gt;&#xa;:9999 · :15000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#FF8800;fontColor=#333333;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Sources: cam1-4 + stream_blanker -->
        <mxCell id="sources" value="cam1–cam4&#xa;stream_blanker&#xa;intro" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="150" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- Telemetry -->
        <mxCell id="telemetry" value="telemetría&#xa;:8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="160" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- RabbitMQ (separate network) -->
        <mxCell id="rabbitmq" value="RabbitMQ&#xa;:5672 · :15672" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="160" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- voctogui (native) -->
        <mxCell id="voctogui" value="&lt;b&gt;voctogui.py&lt;/b&gt; (nativo)&#xa;host = localhost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="290" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow: sources → voctocore -->
        <mxCell id="a1" value=":10000–10005" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="sources" target="voctocore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctocore → telemetry -->
        <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="voctocore" target="telemetry" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: telemetry → rabbitmq (AMQP, dashed) -->
        <mxCell id="a3" value="AMQP" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#d6b656;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="telemetry" target="rabbitmq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: voctogui → voctocore (control) -->
        <mxCell id="a4" value=":9999 control TCP" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeWidth=2;strokeColor=#82b366;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="voctogui" target="voctocore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
